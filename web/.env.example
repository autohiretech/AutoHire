# AutoHire web — environment variables. Copy to `.env` and adjust.

# Data source. Defaults to the hardcoded mock client (no backend needed).
# Set to "false" to run against the real Supabase-backed client (Stage B).
# The mock stays available behind this flag for offline/demo/dev for as long as you want.
VITE_USE_MOCK=true

# --- Supabase (Stage B; unused while VITE_USE_MOCK=true) ---
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
