# AutoHire web — environment variables. Copy to `.env` and adjust.
# The app is Supabase-only, so these are required to run it.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Stripe publishable key (pk_test_… to start). The secret key lives only in the
# create-payment-intent Edge Function's secrets, never here.
VITE_STRIPE_PUBLISHABLE_KEY=
